// 

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- UTENTI (Login) ---
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

// --- CRM (Clienti) ---
model Customer {
  id             String    @id @default(uuid())
  firstName      String
  lastName       String
  email          String?   @unique
  phone          String    @unique
  consentMarketing Boolean  @default(true)
  
  notes          String?
  
  vehicles       Vehicle[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// --- VEICOLI ---
model Vehicle {
  id              String    @id @default(uuid())
  plate           String    @unique
  model           String
  chassisNumber   String?
  registrationDate DateTime?
  
  kmCount         Int       @default(0)

  // Campi per automazione scadenze
  lastRevisionDate DateTime?
  lastOilChange    DateTime?
  
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  jobs            Job[]
  createdAt       DateTime  @default(now())
}

// --- OFFICINA (Schede Lavoro) ---
model Job {
  id          String    @id @default(uuid())
  
  vehicleId   String
  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id])
 
  // STATI: "SCHEDULATO", "IN_LAVORAZIONE", "ATTESA_RICAMBI", "COMPLETATO", "CONSEGNATO"
  status      String    @default("SCHEDULATO") 
  description String
  internalNotes String? // Note interne per i meccanici

  // Costi e preventivi
  laborCost   Float     @default(0)
  partsCost   Float     @default(0)
  totalCost   Float     @default(0)
  
  kmCount     Int // Km registrati all'ingresso
  
  items       JobItem[]

  // Workflow temporale
  scheduledDate DateTime? // <--- QUESTO È IL CAMPO CHE MANCAVA
  startDate     DateTime? // Data inizio lavori effettivi
  endDate       DateTime? // Data fine lavori
  
  // Collegamento alla fattura (1 Job può avere 1 Fattura)
  invoice     Invoice?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// --- CONTABILITÀ (Nuovo Modello) ---
model Invoice {
  id          String    @id @default(uuid())
  number      Int       // Numero progressivo annuale (es. 1, 2, 3...)
  year        Int       // Anno di riferimento (es. 2024)
  
  jobId       String    @unique
  job         Job       @relation(fields: [jobId], references: [id])
  
  amount      Float     // Imponibile
  taxRate     Float     @default(22.0) // IVA
  totalAmount Float     // Totale
  
  isPaid      Boolean   @default(false)
  paidAt      DateTime?
  
  issuedAt    DateTime  @default(now())

  @@unique([year, number])
}

// --- MAGAZZINO ---
model Part {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  description   String?
  stockQuantity Int       @default(0)
  minThreshold  Int       @default(5)
  buyPrice      Float
  sellPrice     Float
  
  jobItems      JobItem[]
}

// --- RELAZIONE PEZZI USATI NEI LAVORI ---
model JobItem {
  id        String  @id @default(uuid())
  jobId     String
  job       Job     @relation(fields: [jobId], references: [id])
  
  partId    String
  part      Part    @relation(fields: [partId], references: [id])
  
  quantity  Int     @default(1)
  unitPrice Float
}