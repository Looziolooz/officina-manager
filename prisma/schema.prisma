generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- UTENTI ---
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

// --- CRM (Clienti) ---
model Customer {
  id                String             @id @default(uuid())
  firstName         String
  lastName          String
  email             String?
  phone             String             @unique
  consentMarketing  Boolean            @default(true)
  familyNotes       String?
  notes             String?
  
  vehicles          Vehicle[]
  accountingRecords AccountingRecord[] // Collegamento con la contabilità
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

// --- VEICOLI ---
model Vehicle {
  id                String    @id @default(uuid())
  plate             String    @unique
  model             String
  year              Int?
  chassisNumber     String?
  registrationDate  DateTime?
  kmCount           Int       @default(0)

  lastRevisionDate  DateTime?
  lastOilChange     DateTime?
  
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  jobs              Job[]
  createdAt         DateTime  @default(now())

  @@index([plate])
}

// --- OFFICINA ---
model Job {
  id               String            @id @default(uuid())
  vehicleId        String
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id])
  status           String            @default("SCHEDULATO") 
  description      String
  internalNotes    String?   
  laborCost        Float             @default(0)
  partsCost        Float             @default(0)
  totalCost        Float             @default(0)
  kmCount          Int       
  items            JobItem[]
  scheduledDate    DateTime?
  startDate        DateTime? 
  endDate          DateTime? 
  invoice          Invoice?
  accountingRecord AccountingRecord? // Collegamento con la contabilità
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

// --- VOCI DI SPESA ---
model JobItem {
  id          String  @id @default(uuid())
  jobId       String
  job         Job     @relation(fields: [jobId], references: [id])
  partId      String? 
  part        Part?   @relation(fields: [partId], references: [id])
  description String  
  quantity    Int     @default(1)
  unitPrice   Float   
  unitCost    Float   @default(0)
}

// --- CONTABILITÀ AVANZATA (Nuovo) ---
model AccountingRecord {
  id          String   @id @default(uuid())
  amount      Float    // Totale incassato (IVA incl.)
  margin      Float    // Guadagno effettivo (Totale - Costo Ricambi)
  type        String   // "ENTRATA" o "USCITA"
  category    String   // "OFFICINA", "MAGAZZINO", "ALTRO"
  description String?
  createdAt   DateTime @default(now())
  
  // Relazione con il lavoro in officina
  jobId       String?  @unique
  job         Job?     @relation(fields: [jobId], references: [id])
  
  // Relazione con il cliente
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
}

// --- SPESE AZIENDALI (Generiche) ---
model BusinessExpense {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  description String
  amount      Float
  category    String   
  notes       String?
}

// --- FATTURAZIONE ---
model Invoice {
  id          String    @id @default(uuid())
  number      Int       
  year        Int       
  jobId       String    @unique
  job         Job       @relation(fields: [jobId], references: [id])
  amount      Float     
  taxRate     Float     @default(22.0)
  totalAmount Float     
  isPaid      Boolean   @default(false)
  paidAt      DateTime?
  issuedAt    DateTime  @default(now())

  @@unique([year, number])
}

// --- MAGAZZINO ---
model Part {
  id            String    @id @default(uuid())
  code          String    @unique
  name          String
  category      String?   @default("RICAMBI")
  description   String?
  stockQuantity Int       @default(0)
  minThreshold  Int       @default(5)
  buyPrice      Float
  sellPrice     Float
  jobItems      JobItem[]
}